{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md",
  ],
  "agent": {
    "build": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.3
    },
    "plan": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "notion": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}