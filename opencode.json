{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/rules/*.md"],
  "agent": {
    "build": {
      "temperature": 0.3,
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "temperature": 0.1,
      "permission": {
        "task": {
          "architect": "allow",
          "code-reviewer": "allow",
          "debugger": "allow",
          "module-builder": "deny",
          "test-writer": "deny"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "notion": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
