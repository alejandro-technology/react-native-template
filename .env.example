# API Configuration
API_URL=https://api.example.com

# Service Provider: http | firebase | supabase | mock
SERVICE_PROVIDER=mock

# Root credentials for mock authentication (optional)
ROOT_USERNAME=user@example.com
ROOT_PASSWORD=example123

# Supabase (required when SERVICE_PROVIDER=supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
